<% layout("./layouts/boilerplate")%>
<div class="row mt-3">
  <div class="col-8 offset-3">
    <h3><%=list.title%></h3>
  </div>
  <div class="card col-6 offset-3 show-card listing-card">
    <img src="<%=list.image.url%>" class="card-img-top show-img" alt="listing" />
    <div class="card-body">
      <br />
      <p class="card-text">Owned by : <%=list.owner.username%></p>
      <p class="card-text"><%=list.description%></p>
      <p class="card-text">&#8360; <%=list.price.toLocaleString("en-PK")%></p>
      <p class="card-text"><%=list.location%></p>
      <p class="card-text"><%=list.country%></p>
    </div>
  </div>
  <%if(currUser && currUser._id.equals(list.owner._id)){%>
  <div class="btns mb-5">
    <a href="/listing/<%=list._id%>/edit" class="btn btn-dark col-1 offset-3"
      >Edit</a
    >
    <form method="post" action="/listing/<%= list._id%>?_method=delete">
      <button class="btn btn-dark add-btn offset-4">Delete</button>
    </form>
  </div>
  <%}%>
  <div class="col-6 offset-3 mb-3">
    <% if(currUser) {%>
    <hr />
    <h4>Leave a Review</h4>
    <div>
      <form
        action="/listing/<%= list._id%>/reviews"
        method="post"
        novalidate
        class="needs-validation"
      >
        <div class="mb-3 mt-3">
          <label for="rating" class="form-label">Rating</label>
          <fieldset class="starability-coinFlip">
            <input
              type="radio"
              id="no-rate"
              class="input-no-rate"
              name="review[rating]"
              value="1"
              checked
              aria-label="No rating."
            />
            <input
              type="radio"
              id="first-rate1"
              name="review[rating]"
              value="1"
            />
            <label for="first-rate1" title="Terrible">1 star</label>
            <input
              type="radio"
              id="first-rate2"
              name="review[rating]"
              value="2"
            />
            <label for="first-rate2" title="Not good">2 stars</label>
            <input
              type="radio"
              id="first-rate3"
              name="review[rating]"
              value="3"
            />
            <label for="first-rate3" title="Average">3 stars</label>
            <input
              type="radio"
              id="first-rate4"
              name="review[rating]"
              value="4"
            />
            <label for="first-rate4" title="Very good">4 stars</label>
            <input
              type="radio"
              id="first-rate5"
              name="review[rating]"
              value="5"
            />
            <label for="first-rate5" title="Amazing">5 stars</label>
          </fieldset>
        </div>
        <div class="mb-3 mt-3">
          <label for="comment" class="form-label">Comment</label>
          <textarea
            name="review[comment]"
            id="comment"
            cols="30"
            rows="5"
            class="form-control"
            required
          ></textarea>
          <div class="invalid-feedback">Please write a comment for review</div>
        </div>
        <button class="btn btn-outline-dark mt-1">Submit</button>
      </form>
      <hr />
    </div>
    <%}%>
    <p><b>All Reviews</b></p>
    <div class="row">
      <% if (list.reviews && list.reviews.length > 0) { %> <% for (let review of
      list.reviews) { %>
      <div class="card col-5 mb-3 ms-3 mt-2">
        <div class="card-body">
          <h5 class="card-title"><%=review.author.username%></h5>
          <p
            class="starability-result card-text"
            data-rating="<%=review.rating%>"
          >
          </p>
          <p class="card-text"><%=review.comment%></p>
        </div>
        <form
          class="mb-3"
          action="/listing/<%=list._id%>/reviews/<%=review._id%>?_method=DELETE"
          method="post"
        >
          <%if(currUser && currUser._id.equals(review.author._id)){%>
            <br>
          <button class="btn btn-sm btn-dark">Delete</button>
          <%}%>
        </form>
      </div>
      <% } %> <% } else { %>
      <p>No reviews yet.</p>
      <% } %>
    </div>
  </div>

  <div class="col-6 offset-3">
    <h3>Where you'll be</h3>
<gmp-map
  center="<%= list.geometry.coordinates[1] %>,<%= list.geometry.coordinates[0] %>"
  zoom="12"
  map-id="DEMO_MAP_ID"
  style="height: 400px"
>
  <gmp-advanced-marker
    position="<%= list.geometry.coordinates[1] %>,<%= list.geometry.coordinates[0] %>"
  >
    <div class="marker-wrapper">

      <!-- POPUP -->
      <div class="popup">
        <h6><%= list.title %></h6>
        <p>Exact location provided after booking.</p>
      </div>

      <!-- MARKER -->
      <div class="custom-marker">
        <i class="fa-solid fa-house"></i>
      </div>

    </div>
  </gmp-advanced-marker>
</gmp-map>
   <br>
  </div>
</div>
<script
  src="https://maps.googleapis.com/maps/api/js?key=<%= process.env.MAP_KEY %>&libraries=maps,marker"
  async
  defer
></script>